{
  "name": "@pablovitasso/szkrabok",
  "version": "2.0.10",
  "description": "Production-grade MCP browser automation layer with persistent sessions and stealth capabilities",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./runtime": "./packages/runtime/index.js",
    "./fixtures": "./src/fixtures.js"
  },
  "imports": {
    "#runtime": "./packages/runtime/index.js"
  },
  "files": [
    "bin",
    "src",
    "packages/runtime",
    "patches",
    "scripts",
    "README.md"
  ],
  "bin": {
    "szkrabok": "bin/szkrabok.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/runtime"
  ],
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --write \"{src,tests}/**/*.{js,json,md}\" \"*.{js,json,md}\"",
    "format": "npm run prettier",
    "format:check": "prettier --check \"{src,tests}/**/*.{js,json,md}\" \"*.{js,json,md}\"",
    "codegen:mcp": "node packages/runtime/mcp-client/codegen/generate-mcp-tools.mjs",
    "prepack": "git describe --exact-match --tags HEAD 2>/dev/null || (echo 'ERROR: HEAD is not tagged. Run npm run release:patch or release:minor first.' && exit 1)",
    "prepublishOnly": "npm run lint && node scripts/smoke-test.js",
    "release:patch": "npm version patch --workspaces --include-workspace-root --ignore-scripts --no-git-tag-version && node scripts/release-commit.js",
    "release:minor": "npm version minor --workspaces --include-workspace-root --ignore-scripts --no-git-tag-version && node scripts/release-commit.js",
    "deps:update": "npx npm-check-updates -u --workspaces && npm install",
    "release:publish": "node scripts/release-publish.js",
    "release:github": "node scripts/release-github.js",
    "test": "npm run test:self && npm run test:auto",
    "test:node": "echo 'This test is disabled. Use npm test instead'",
    "test:runtime:unit": "node --test tests/node/runtime/unit.test.js",
    "test:runtime:integration": "node --test tests/node/runtime/integration.test.js",
    "test:contracts": "node --test tests/node/contracts.test.js",
    "test:playwright": "playwright test --project=integration",
    "prepare": "node scripts/setup.js",
    "postinstall": "node scripts/apply-patches.js && node scripts/verify-playwright-patches.js",
    "test:self": "npm run lint && playwright test --project=integration && node --test tests/node/*.test.js",
    "test:auto": "PLAYWRIGHT_PROJECT=e2e playwright test --project=e2e"
  },
  "keywords": [
    "mcp",
    "playwright",
    "browser-automation",
    "stealth",
    "session-management",
    "llm-tools",
    "web-scraping",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PabloVitasso/szkrabok.git"
  },
  "dependencies": {
    "@babel/generator": "7.29.1",
    "@babel/parser": "7.29.2",
    "@babel/traverse": "7.29.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "patch-package": "8.0.1",
    "commander": "14.0.3",
    "dotenv": "17.4.1",
    "playwright": "1.59.1",
    "playwright-core": "1.59.1",
    "playwright-extra": "4.3.6",
    "puppeteer-core": "24.40.0",
    "puppeteer-extra-plugin-stealth": "2.11.2",
    "smol-toml": "1.6.1",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.49.1"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-node": "11.1.0",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "puppeteer-extra": "3.3.6"
  },
  "eslintConfig": {
    "_comment": "Ignored by ESLint 9+ — rules live in eslint.config.js"
  }
}
